{
  "name": "agent007",
  "description": "Agent007 - Autonomous AI Development Team. 5 expert agents, 42 skills, 16 commands — /dev auto-classifies and routes tasks, /ralph-loop iterates until completion, /consult injects domain expert context. Cross-platform (macOS/Linux/Windows). First-session welcome banner.",
  "version": "4.1.0",
  "author": {
    "name": "Sebastian Guerra",
    "email": "guerrasebastian16@gmail.com"
  },
  "homepage": "https://github.com/SebastianDevps/agent007",
  "repository": "https://github.com/SebastianDevps/agent007.git",
  "license": "MIT",
  "keywords": [
    "orchestration",
    "agents",
    "experts",
    "autonomous",
    "ralph-loop",
    "backend",
    "frontend",
    "platform",
    "security",
    "product",
    "tdd",
    "debugging",
    "architecture",
    "code-review",
    "nestjs",
    "react",
    "consultation",
    "worktrees",
    "subagents",
    "planning"
  ],
  "commands": "./commands/",
  "agents": "./agents/",
  "skills": "./skills/",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/welcome.py"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/memory-check.py"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/subagent-start.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/ralph-check.js"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/stop-state-sync.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/agent007-statusline.js"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/sdd-test-guard.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/context-window-guard.py"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/format-on-save.py"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/sdd-auto-test.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/constraint-reinforcement.py"
          }
        ]
      }
    ]
  },
  "features": [
    "Autonomous task classification and routing (simple/medium/complex)",
    "Ralph Loop: iterates until <promise>COMPLETE</promise> detected",
    "Stop hook blocks premature stops and injects continuation context",
    "Git worktrees for isolated feature development",
    "Subagent-driven execution with spec + quality review per task",
    "Cross-session state persistence via STATE.md",
    "Auto-selects expert agent by keyword matching",
    "Two-stage code review (spec compliance + code quality)",
    "Keyboard shortcuts in brainstorming (A/D/E)"
  ]
}
